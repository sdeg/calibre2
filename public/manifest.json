{
  "manifest_version": 3,
  "name": "Calibre — Bloc-notes",
  "description": "Prise de notes rapide avec sauvegarde automatique",
  "version": "0.1.8",
  "action": {
    "default_title": "Calibre — Bloc-notes",
    "default_icon": {
      "16": "icons/icn-calibre-16.png",
      "48": "icons/icn-calibre-48.png",
      "128": "icons/icn-calibre-128.png"
    }
  },
  "icons": {
    "16": "icons/icn-calibre-16.png",
    "48": "icons/icn-calibre-48.png",
    "128": "icons/icn-calibre-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["sidePanel"]
}
